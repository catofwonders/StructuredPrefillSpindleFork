{
  "version": "1.0.0",
  "name": "StructuredPrefill",
  "identifier": "structured_prefill",
  "author": "mia13165",
  "github": "https://github.com/mia13165/StructuredPrefill",
  "homepage": "https://rentry.org/structuredprefill",
  "description": "Prefill-like behavior using Structured Outputs (json_schema) instead of assistant-role prefills. Ported from SillyTavern to Lumiverse Spindle.",
  "permissions": ["interceptor", "generation", "chat_mutation"],
  "entry_backend": "dist/backend.js",
  "entry_frontend": "dist/frontend.js",
  "minimum_lumiverse_version": "0.1.0",
  "storage_seed_files": [
    { "from": "defaults/settings.json", "to": "settings.json", "overwrite": false }
  ]
}
